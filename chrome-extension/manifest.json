{
  "manifest_version": 3,
  "name": "Focus Rooms",
  "version": "1.0",
  "description": "Tracks distractions during your Focus Rooms session",

  "permissions": [
    "tabs",
    "storage"
  ],

  "host_permissions": [
    "http://localhost:8000/*"
  ],

  "content_scripts": [
    {
      "matches": ["http://localhost:5173/*"],
      "js": ["content.js"]
    }
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Focus Rooms"
  }
}
